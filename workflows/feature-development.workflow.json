{
  "id": "feature-development",
  "name": "Feature development",
  "steps": ["discovery", "research", "spec", "experience", "plan", "tasks", "build", "verify", "release"],
  "gates": {
    "research": ["discovery"],
    "spec": ["approved-discovery"],
    "experience": ["approved-spec"],
    "plan": ["approved-spec", "experience-complete"],
    "tasks": ["approved-plan"],
    "build": ["tasks"],
    "verify": ["build", "test-evidence"],
    "release": ["verify-passed", "release-approved"]
  },
  "artifacts": {
    "discovery": ["discovery/discovery-report.md"],
    "research": ["research/research-report.md", "research/evidence-log.md", "research/alternatives.md"],
    "spec": ["spec.md"],
    "experience": ["experience/<surface>.md", "experience/<surface>.contract.json"],
    "plan": ["plans/implementation-plan.md"],
    "tasks": ["tasks/tasks.md"],
    "verify": ["reports/verify/report.md"],
    "release": ["reports/release/release-notes.md"]
  },
  "loops": {
    "verify": {
      "predicate": [
        "every acceptance criterion in the spec is demonstrably met",
        "the full test suite passes with no regressions",
        "the step validation command passes"
      ],
      "maxIterations": 8,
      "patience": 3,
      "onContinue": "build",
      "gates": ["G-acceptance", "G-build", "G-lint", "G-typecheck", "G-tests", "G-runtime-clean"]
    }
  },
  "gateCatalog": {
    "G-build": { "description": "Build command succeeds.", "runner": "<repo build command>", "passCriteria": "exit 0" },
    "G-lint": { "description": "Lint passes.", "runner": "<repo lint command>", "passCriteria": "exit 0, no errors" },
    "G-typecheck": { "description": "Typecheck passes.", "runner": "<repo typecheck command>", "passCriteria": "exit 0" },
    "G-tests": { "description": "Test suite passes with no regressions.", "runner": "<repo test command>", "passCriteria": "all tests pass" },
    "G-runtime-clean": { "description": "Runtime has no unexpected errors.", "runner": "<smoke/runtime check>", "passCriteria": "no unexpected errors logged" },
    "G-routes-200": { "description": "Routes or endpoints respond successfully.", "runner": "<http/route check>", "passCriteria": "expected status codes", "conditional": true, "appliesTo": ["screen", "flow", "api"] },
    "G-assets-present": { "description": "Referenced assets exist.", "runner": "manual", "passCriteria": "every asset named in the experience contract resolves" },
    "G-imports-used": { "description": "Named primitives/modules are implemented or imported where expected.", "runner": "manual", "passCriteria": "no named dependency is missing or substituted" },
    "G-acceptance": { "description": "Every acceptance criterion in the spec is demonstrably met.", "runner": "manual", "passCriteria": "each criterion has evidence" },
    "G-visual": { "description": "Visual output matches the approved reference.", "runner": "<visual diff>", "passCriteria": "diff under threshold", "conditional": true, "appliesTo": ["screen", "flow"] }
  },
  "stopConditions": [
    "the problem, target user, or desired outcome is unclear after discovery",
    "specification is attempted before research findings are recorded (research must precede spec)",
    "spec scope or target user is ambiguous",
    "the plan would commit to an architecture the project has not used",
    "a gate's required decision is still pending (pending is not approved)",
    "release is attempted before the verify report shows acceptance criteria are met"
  ],
  "validation": {
    "verify": "make validate-harness"
  }
}
